{
  "name": "AssemblyOrder",
  "type": "object",
  "properties": {
    "order_number": {
      "type": "string",
      "title": "\u041d\u043e\u043c\u0435\u0440 \u0437\u0430\u043a\u0430\u0437\u0430"
    },
    "client_email": {
      "type": "string",
      "title": "Email \u043a\u043b\u0438\u0435\u043d\u0442\u0430"
    },
    "client_name": {
      "type": "string",
      "title": "\u0418\u043c\u044f \u043a\u043b\u0438\u0435\u043d\u0442\u0430"
    },
    "status": {
      "type": "string",
      "title": "\u0421\u0442\u0430\u0442\u0443\u0441",
      "enum": [
        "\u043d\u043e\u0432\u0430\u044f",
        "\u0432 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0435",
        "\u0432 \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0442\u043e\u0432\u043a\u0435",
        "\u0443\u043f\u0430\u043a\u043e\u0432\u0430\u043d\u0430",
        "\u043e\u0442\u0433\u0440\u0443\u0436\u0435\u043d\u0430",
        "\u043e\u0442\u043c\u0435\u043d\u0435\u043d\u0430"
      ],
      "default": "\u043d\u043e\u0432\u0430\u044f"
    },
    "items": {
      "type": "array",
      "title": "\u0422\u043e\u0432\u0430\u0440\u044b \u0434\u043b\u044f \u0441\u0431\u043e\u0440\u043a\u0438",
      "items": {
        "type": "object",
        "properties": {
          "product_name": {
            "type": "string"
          },
          "sku": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "honest_mark": {
            "type": "string"
          }
        }
      }
    },
    "marketplace": {
      "type": "string",
      "title": "\u041c\u0430\u0440\u043a\u0435\u0442\u043f\u043b\u0435\u0439\u0441",
      "enum": [
        "WB",
        "Ozon",
        "\u0414\u0440\u0443\u0433\u043e\u0435"
      ]
    },
    "destination_warehouse": {
      "type": "string",
      "title": "\u0421\u043a\u043b\u0430\u0434 \u043d\u0430\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u044f"
    },
    "packaging_type": {
      "type": "string",
      "title": "\u0422\u0438\u043f \u0443\u043f\u0430\u043a\u043e\u0432\u043a\u0438",
      "enum": [
        "zip-\u043f\u0430\u043a\u0435\u0442",
        "\u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0430\u044f \u043a\u043e\u0440\u043e\u0431\u043a\u0430",
        "\u0441\u0440\u0435\u0434\u043d\u044f\u044f \u043a\u043e\u0440\u043e\u0431\u043a\u0430",
        "\u0431\u043e\u043b\u044c\u0448\u0430\u044f \u043a\u043e\u0440\u043e\u0431\u043a\u0430"
      ]
    },
    "cargo_places": {
      "type": "number",
      "title": "\u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0433\u0440\u0443\u0437\u043e\u043c\u0435\u0441\u0442"
    },
    "comment": {
      "type": "string",
      "title": "\u041a\u043e\u043c\u043c\u0435\u043d\u0442\u0430\u0440\u0438\u0439"
    },
    "operator_comment": {
      "type": "string",
      "title": "\u041a\u043e\u043c\u043c\u0435\u043d\u0442\u0430\u0440\u0438\u0439 \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0430"
    },
    "processed_by": {
      "type": "string",
      "title": "\u041e\u0431\u0440\u0430\u0431\u043e\u0442\u0430\u043b"
    },
    "shipped_date": {
      "type": "string",
      "title": "\u0414\u0430\u0442\u0430 \u043e\u0442\u0433\u0440\u0443\u0437\u043a\u0438"
    }
  },
  "required": [
    "order_number",
    "client_email",
    "status",
    "marketplace"
  ]
}